# Configuración del despliegue self-hosted (docker compose).
# 1) Copia este fichero:  cp deploy/selfhosted.env.example deploy/selfhosted.env
# 2) Cambia TODOS los valores marcados con CAMBIAME.
# deploy/selfhosted.env está en .gitignore/.dockerignore: nunca se sube.

# --- Postgres (servicio "db" del compose) ---
POSTGRES_USER=crochety
POSTGRES_DB=crochety
POSTGRES_PASSWORD=CAMBIAME-password-bd

# OJO: la contraseña de arriba aparece también dentro de estas dos URLs.
# Sin pgbouncer no hay distinción pooled/directa: misma URL en ambas.
DATABASE_URL=postgresql://crochety:CAMBIAME-password-bd@db:5432/crochety
DATABASE_URL_UNPOOLED=postgresql://crochety:CAMBIAME-password-bd@db:5432/crochety

# --- Auth.js ---
# Genera uno propio: openssl rand -base64 32   (o: npx auth secret)
AUTH_SECRET=CAMBIAME-secreto-auth
AUTH_TRUST_HOST=true

# --- Usuarios (los crea/actualiza el servicio "migrate" en cada arranque) ---
USER1_NAME=CAMBIAME
USER1_EMAIL=CAMBIAME@example.com
USER1_PASSWORD=CAMBIAME
USER2_NAME=CAMBIAME
USER2_EMAIL=CAMBIAME2@example.com
USER2_PASSWORD=CAMBIAME

# --- IA (estandarización de patrones y extracción de gastos) ---
# AI_PROVIDER: anthropic | openai | openrouter | ollama
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=CAMBIAME
# El modelo debe soportar structured outputs (trampa #11 de AGENTS.md).
AI_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Los ficheros subidos van al volumen docker "uploads" (UPLOAD_DIR ya viene
# fijado en la imagen); no hay que configurar Vercel Blob.

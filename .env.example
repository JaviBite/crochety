# Copia este fichero a .env y rellena los valores.

# --- Base de datos (Postgres/Neon) ---
# DATABASE_URL: URL "pooled" (runtime). DATABASE_URL_UNPOOLED: conexión directa,
# la usa el CLI de Prisma (migrate/seed/studio). En Vercel las inyecta la
# integración de Neon; en local: `vercel env pull .env.development.local`
# o un Postgres local (docker run postgres).
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""

# --- Autenticación (Auth.js) ---
# Genera uno propio: npx auth secret  (o: openssl rand -base64 32)
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# --- Usuarios (creados/actualizados por `npm run db:seed`) ---
USER1_NAME=""
USER1_EMAIL=""
USER1_PASSWORD=""
USER2_NAME=""
USER2_EMAIL=""
USER2_PASSWORD=""

# --- Ficheros subidos (Vercel Blob) ---
# Token del store de Blob; en Vercel lo inyecta la integración, en local
# se obtiene con `vercel env pull`.
BLOB_READ_WRITE_TOKEN=""

# --- IA (agente de estandarización de patrones) ---
# AI_PROVIDER: anthropic | openai | openrouter | ollama
# Con openrouter, AI_MODEL por defecto es "openrouter/free" (router automático
# de modelos gratuitos); se puede fijar uno concreto, p. ej. "deepseek/deepseek-r1:free".
AI_PROVIDER="anthropic"
AI_MODEL="claude-opus-4-8"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434/v1"

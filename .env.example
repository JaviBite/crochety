# Copia este fichero a .env y rellena los valores.

# --- Base de datos (Postgres) ---
# DATABASE_URL: URL "pooled" (runtime). DATABASE_URL_UNPOOLED: conexión directa,
# la usa el CLI de Prisma (migrate/seed/studio); si no se define, cae a
# DATABASE_URL. En Vercel las inyecta la integración de Neon.
# Dev local (docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=dev postgres:17):
DATABASE_URL="postgresql://postgres:dev@localhost:5432/postgres"
DATABASE_URL_UNPOOLED=""

# --- Autenticación (Auth.js) ---
# Genera uno propio: npx auth secret  (o: openssl rand -base64 32)
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# --- Usuarios (creados/actualizados por `npm run db:seed`) ---
USER1_NAME=""
USER1_EMAIL=""
USER1_PASSWORD=""
USER2_NAME=""
USER2_EMAIL=""
USER2_PASSWORD=""

# --- Ficheros subidos ---
# Con BLOB_READ_WRITE_TOKEN los uploads van a Vercel Blob (producción; en
# Vercel lo inyecta la integración). SIN token van a disco local (UPLOAD_DIR,
# ./uploads por defecto) — desarrollo offline sin servicios externos.
BLOB_READ_WRITE_TOKEN=""
UPLOAD_DIR="./uploads"

# --- IA (agente de estandarización de patrones) ---
# AI_PROVIDER: anthropic | openai | openrouter | ollama
# Con openrouter, AI_MODEL por defecto es "openrouter/free" (router automático
# de modelos gratuitos); se puede fijar uno concreto, p. ej. "deepseek/deepseek-r1:free".
AI_PROVIDER="anthropic"
AI_MODEL="claude-opus-4-8"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434/v1"

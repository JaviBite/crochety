# Copia este fichero a .env y rellena los valores.

# --- Base de datos (SQLite) ---
# En desarrollo: fichero local. En Docker se sobreescribe a file:/app/data/crochety.db
DATABASE_URL="file:./data/crochety.db"

# --- Autenticación (Auth.js) ---
# Genera uno propio: npx auth secret  (o: openssl rand -base64 32)
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# --- Usuarios (creados/actualizados por `npm run db:seed`) ---
USER1_NAME=""
USER1_EMAIL=""
USER1_PASSWORD=""
USER2_NAME=""
USER2_EMAIL=""
USER2_PASSWORD=""

# --- Ficheros subidos ---
UPLOAD_DIR="./uploads"

# --- IA (agente de estandarización de patrones) ---
# AI_PROVIDER: anthropic | openai | ollama
AI_PROVIDER="anthropic"
AI_MODEL="claude-opus-4-8"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434/v1"
